<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let real files and folders (css, js, images) load normally
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Everything else goes through index.html so React Router can handle it
  RewriteRule . /index.html [L]
</IfModule>
